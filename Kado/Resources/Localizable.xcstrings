  "strings" : {
    "%@, %@" : {
      "comment" : "VoiceOver label for a binary or negative habit row. First arg: habit name. Second arg: localized completion state ('done' or 'not done').",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@, %2$@"
          }
        }
      }
    },
