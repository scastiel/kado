      "comment" : "VoiceOver label for a counter habit row. First arg: habit name. Second arg: target count.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@, counter, target %2$lld"
          }
        }
      }
    },
    "%@, score %lld percent" : {
      "comment" : "VoiceOver value for a counter or timer Today row when the habit has no current streak. First arg: today's progress (e.g. '3 of 8'). Second arg: EMA score percent (0-100).",
