        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@, score %2$lld percent"
          }
        }
      }
    },
    "%@, streak %lld, score %lld percent" : {
      "comment" : "VoiceOver value for a counter or timer Today row when the habit has a non-zero streak. First arg: today's progress (e.g. '3 of 8'). Second arg: streak length in days. Third arg: EMA score percent (0-100).",
